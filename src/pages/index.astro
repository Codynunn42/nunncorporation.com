<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Nunn Corporation — reliable services and solutions you can count on."
    />
    <title>Nunn Corporation</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="site-header">
      <span class="logo">Nunn<span>Corporation</span></span>
    </header>

    <section class="hero">
      <h1>Solutions You Can Count On</h1>
      <p>
        Nunn Corporation delivers dependable services and innovative solutions
        tailored to meet your needs.
      </p>
      <a href="#contact" class="btn">Get in Touch</a>
    </section>

    <main>
      <div class="container">
        <section class="services">
          <h2>What We Do</h2>
          <div class="services-grid">
            <div class="service-card">
              <h3>Consulting</h3>
              <p>
                Strategic guidance to help your business grow efficiently and
                sustainably.
              </p>
            </div>
            <div class="service-card">
              <h3>Development</h3>
              <p>
                Custom software and web solutions built to fit your exact
                specifications.
              </p>
            </div>
            <div class="service-card">
              <h3>Support</h3>
              <p>
                Ongoing maintenance and support so your operations run without
                interruption.
              </p>
            </div>
          </div>
        </section>

        <section class="contact" id="contact">
          <h2>Contact Us</h2>
          <form
            name="contact"
            method="POST"
            data-netlify="true"
          >
            <input type="hidden" name="form-name" value="contact" />
            <div class="form-group">
              <label for="name">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                placeholder="Your full name"
                required
              />
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="you@example.com"
                required
              />
            </div>
            <div class="form-group">
              <label for="message">Message</label>
              <textarea
                id="message"
                name="message"
                placeholder="How can we help you?"
                required
              ></textarea>
            </div>
            <button type="submit" class="btn form-submit">Send Message</button>
          </form>
        </section>
      </div>
    </main>

    <footer class="site-footer">
      <p>
        &copy; 2024 Nunn Corporation. All rights reserved.
      </p>
    </footer>
  </body>
</html>
